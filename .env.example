# Copy to .env and adjust. Defaults are free + local.

# --- LLM provider -------------------------------------------------------
# "ollama" = local & free (default).  "anthropic" = frontier API (costs money).
LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.1

# Only needed if LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# CHAT_MODEL=claude-sonnet-4-6

# --- Embeddings ---------------------------------------------------------
# Leave unset for the free local hashing embedder (dev/CI).
# Set to 1 to use a real embedding API (needs VOYAGE_API_KEY).
# USE_REAL_EMBED=1
# VOYAGE_API_KEY=...
